# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3003
APP_URL=http://localhost:3003
FRONTEND_URL=http://localhost:3002

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://sde:Lrg911vdC!@172.16.0.50:5432/storage_app"

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage ──────────────────────────────────────────────────
STORAGE_ROOT=D:\Storage
MAX_FILE_SIZE_MB=5000
ALLOWED_EXTENSIONS=*
THUMBNAIL_MAX_WIDTH=400
THUMBNAIL_MAX_HEIGHT=400
PREVIEW_MAX_WIDTH=1200
PREVIEW_MAX_HEIGHT=1200

# ─── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ─── Cors ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Virus Scan (optional webhook) ───────────────────────────
VIRUS_SCAN_ENABLED=false
VIRUS_SCAN_URL=http://localhost:3310/scan

# ─── Redis (for Bull queues / caching) ────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Email (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=D:\Storage\logs
