    "slugify": "^1.6.6",
    "mime-types": "^2.1.35",
    "file-type": "^16.5.4",
    "crypto-js": "^4.2.0",
    "nanoid": "^3.3.7",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "swagger-ui-express": "^5.0.0",
    "rxjs": "^7.8.1",
    "reflect-metadata": "^0.2.1",
    "date-fns": "^3.3.1",
    "winston": "^3.11.0",
    "nest-winston": "^1.9.4",
    "winston-daily-rotate-file": "^4.7.1",
